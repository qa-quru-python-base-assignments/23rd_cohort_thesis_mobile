# ==============================================================================
# ПРИМЕРЫ КОНФИГУРАЦИОННЫХ ФАЙЛОВ ДЛЯ РАЗНЫХ ОКРУЖЕНИЙ
# ==============================================================================
#
# В проекте используется система контекстов. В зависимости от переменной окружения
# CONTEXT=... (по умолчанию bstack), конфиг `src/utils/config.py` загружает
# соответствующий файл `.env.{context}`.
#
# Также, если CONTEXT=bstack, автоматически подгружается файл `.env.credentials`
#
# Ниже приведены шаблоны для каждого из возможных файлов. 
# Создайте нужные файлы (напр. .env.local_emulator) в корне проекта 
# на основе этих примеров.


# ==============================================================================
# ФАЙЛ: .env.credentials
# (Только логины и пароли для BrowserStack)
# ==============================================================================
# BROWSERSTACK_USERNAME=your_browserstack_username
# BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key


# ==============================================================================
# ФАЙЛ: .env.local_emulator
# (Для запуска на локальном эмуляторе Android Studio)
# Запуск: CONTEXT=local_emulator pytest tests/
# ==============================================================================
# CONTEXT=local_emulator
# REMOTE_URL=http://127.0.0.1:4723
# PLATFORM_NAME=android
# PLATFORM_VERSION=14.0
# DEVICE_NAME=emulator-5554
#
# # Путь к приложению (обязательно абсолютный путь!)
# APPIUM_APP=/Users/username/PycharmProjects/PythonProject/resources/apks/wikipedia.apk
# 
# # Опционально: точное указание пакета и активити (полезно, если возникает ошибка "Intent matches multiple activities")
# APP_PACKAGE=org.wikipedia.alpha
# APP_ACTIVITY=org.wikipedia.main.MainActivity


# ==============================================================================
# ФАЙЛ: .env.bstack
# (Для облачного запуска Android/iOS тестов в BrowserStack)
# Запуск: CONTEXT=bstack pytest tests/
# ==============================================================================
# CONTEXT=bstack
# REMOTE_URL=https://hub.browserstack.com/wd/hub
#
# # Параметры устройства Android/iOS в облаке
# # (Выбираете нужные из https://www.browserstack.com/app-automate/capabilities)
# PLATFORM_NAME=android
# PLATFORM_VERSION=11.0
# DEVICE_NAME=Google Pixel 5
# 
# # Идентификатор загруженного приложения в BrowserStack
# APPIUM_APP=bs://sample.app
# 
# # Опции отчета в BrowserStack
# PROJECT_NAME=App
# BUILD_NAME=Build 1.0
# SESSION_NAME=App Test Session
# LOCAL=false
# DEBUG=true
# NETWORK_LOGS=true
# VIDEO=true
